# ─────────────────────────────────────────────────────────────────────────────
# ConvertFast — Environment Variables
# Copy this file to .env.local for local dev.
# Add all of these to Vercel: Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Your live domain ──────────────────────────────────────────────────────────
# Used for Stripe success/cancel redirect URLs
APP_URL=https://ConvertFast.io


# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → Your App → API Keys
#
# Publishable key goes in public/index.html (replace CLERK_PUBLISHABLE_KEY_PLACEHOLDER)
# Secret key stays server-side only — never put in frontend HTML
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX


# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX

# Webhook secret — get this after creating a webhook endpoint in Stripe:
#   Stripe Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://ConvertFast.io/api/webhook
#   Events to listen for:
#     checkout.session.completed
#     invoice.payment_succeeded
#     invoice.payment_failed
#     customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Product IDs — Stripe Dashboard → Products → click product → copy "Product ID" (prod_XXXX)
# Create 2 products: "ConvertFast Pro" and "ConvertFast Team"
STRIPE_PRODUCT_PRO=prod_XXXXXXXXXXXX
STRIPE_PRODUCT_TEAM=prod_XXXXXXXXXXXX

# Price IDs — inside each product, create 2 prices (monthly + annual recurring)
# Copy the price_XXXX id for each
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXX
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXX
STRIPE_PRICE_TEAM_MONTHLY=price_XXXXXXXXXXXX
STRIPE_PRICE_TEAM_ANNUAL=price_XXXXXXXXXXXX


# ── Supabase (database) ────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
# Use the "service_role" key (not anon) — this bypasses Row Level Security
# NEVER expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXX
